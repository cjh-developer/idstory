<?xml version="1.0" encoding="UTF-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════════╗
    ║         IDStory 비밀번호 암호화 설정 파일                         ║
    ║         위치: src/main/resources/config/password-config.xml      ║
    ╚══════════════════════════════════════════════════════════════════╝

    이 파일을 수정하여 비밀번호 암호화 방식을 변경할 수 있습니다.
    변경 후 애플리케이션을 재시작해야 적용됩니다.

    ※ 주의: 운영 중 알고리즘/인코딩/솔트 변경 시 기존 저장된 비밀번호와
            불일치가 발생합니다. 변경 전 반드시 DB 비밀번호를 재설정하세요.
-->
<password-config>

    <!--
        ┌─────────────────────────────────────────────────────────────┐
        │  알고리즘 (Algorithm)                                        │
        │  사용 가능한 값: SHA256 | SHA512                             │
        │  - SHA256 : SHA-256 (256 bit, 64자 HEX / 44자 BASE64)       │
        │  - SHA512 : SHA-512 (512 bit, 128자 HEX / 88자 BASE64) ← 권장│
        └─────────────────────────────────────────────────────────────┘
    -->
    <algorithm>SHA512</algorithm>

    <!--
        ┌─────────────────────────────────────────────────────────────┐
        │  인코딩 방식 (Encoding)                                      │
        │  사용 가능한 값: HEX | BASE64                                │
        │  - HEX    : 16진수 소문자 문자열 표현  ← 권장 (DB 조회 용이) │
        │  - BASE64 : Base64 인코딩 문자열 표현                        │
        └─────────────────────────────────────────────────────────────┘
    -->
    <encoding>HEX</encoding>

    <!--
        ┌─────────────────────────────────────────────────────────────┐
        │  비밀번호 솔트 사용 여부 (Password Salt Enabled)             │
        │  사용 가능한 값: true | false                                │
        │  - true  : 해싱 시 password-salt 값을 비밀번호 앞에 추가    │
        │            해시 대상: HASH(password-salt + 입력 비밀번호)    │
        │  - false : 솔트 미사용 (입력 비밀번호만 해싱)  ← 기본값     │
        └─────────────────────────────────────────────────────────────┘
    -->
    <password-salt-enabled>false</password-salt-enabled>

    <!--
        ┌─────────────────────────────────────────────────────────────┐
        │  솔트 값 (Password Salt Value)                               │
        │  - password-salt-enabled 가 true 일 때만 적용됩니다         │
        │  - 충분히 복잡한 문자열을 권장합니다                         │
        │  - 예시: IDStr0ry@2024#S3cur1ty!                             │
        │  - sys_users.password_salt 컬럼에 이 값이 함께 저장됩니다   │
        └─────────────────────────────────────────────────────────────┘
    -->
    <password-salt></password-salt>

</password-config>
