        ids_iam_user u 
    LEFT JOIN
        ids_iam_login_hist h   
            ON h.user_oid = u.oid 
            AND h.action_type = 'LOGIN_SUCCESS' 
    WHERE
        u.deleted_at IS NULL 
        AND u.use_yn = 'Y' 
    GROUP BY
        u.oid,
        u.user_id,
        u.name,
        u.dept_code 
    HAVING
        last_login IS NULL 
        OR last_login < DATE_SUB(NOW(), INTERVAL ? DAY) 
    ORDER BY
        (last_login IS NULL) DESC,
        last_login ASC 
    LIMIT
        10
